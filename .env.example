PORTAL_HOST=100.117.91.117
UDP_PORT=20000

# Camera input. Use /dev/video0 for USB CSI cameras, or 0 for default camera index.
SOURCE=/dev/video0

# YOLO inference tuning
YOLO_MODEL=yolov8n.pt
CONF=0.45
IMGSZ=640
COOLDOWN=1.5

# Stream tuning
STREAM_FPS=20
STREAM_WIDTH=1280
STREAM_HEIGHT=720

# Optional overrides
RTSP_TRANSPORT=tcp
HEALTH_PORT=8080
LOG_CSV_PATH=/app/yolo_stream_sender_log.csv
